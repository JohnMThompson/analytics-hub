# Environment variables for local development
# Copy to .env and fill with your actual database credentials

# Mortgage Database
DB_MORTGAGE_HOST=localhost
DB_MORTGAGE_USER=
DB_MORTGAGE_PASSWORD=
DB_MORTGAGE_NAME=
DB_MORTGAGE_PORT=3306

# Swim Database (optional, for future dashboards)
DB_SWIM_HOST=
DB_SWIM_USER=
DB_SWIM_PASSWORD=
DB_SWIM_NAME=
DB_SWIM_PORT=3306

# Home Office Temperature Database (optional; falls back to mortgage credentials if omitted)
DB_RPI_HOST=
DB_RPI_USER=
DB_RPI_PASSWORD=
DB_RPI_NAME=rpi
DB_RPI_PORT=3306

# Halloween Database
DB_HALLOWEEN_HOST=
DB_HALLOWEEN_USER=
DB_HALLOWEEN_PASSWORD=
DB_HALLOWEEN_NAME=halloween
DB_HALLOWEEN_PORT=3306

# Dakota Database
DB_DAKOTA_HOST=
DB_DAKOTA_USER=
DB_DAKOTA_PASSWORD=
DB_DAKOTA_NAME=dakota
DB_DAKOTA_PORT=3306

# App Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=*
ENABLE_MORTGAGE_DASHBOARD=true
ENABLE_SWIM_DASHBOARD=true
ENABLE_RPI_DASHBOARD=true
ENABLE_HALLOWEEN_DASHBOARD=true
ENABLE_DAKOTA_DASHBOARD=true

# Frontend API URL
VITE_API_URL=http://localhost:8000
VITE_GA_MEASUREMENT_ID=

# Public hostname used by Caddy in production override compose
APP_DOMAIN=analytics.example.com
