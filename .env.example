# Environment variables for local development
# Copy to .env and fill with your actual database credentials

# Mortgage Database
DB_MORTGAGE_HOST=localhost
DB_MORTGAGE_USER=
DB_MORTGAGE_PASSWORD=
DB_MORTGAGE_NAME=
DB_MORTGAGE_PORT=3306

# Swim Database (optional, for future dashboards)
DB_SWIM_HOST=
DB_SWIM_USER=
DB_SWIM_PASSWORD=
DB_SWIM_NAME=
DB_SWIM_PORT=3306

# App Configuration
ENVIRONMENT=development
DEBUG=true

# Frontend API URL
REACT_APP_API_URL=http://localhost:8000
